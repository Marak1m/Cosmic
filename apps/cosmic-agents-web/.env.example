# ---- Provider ----
# Prefer OpenRouter (OpenAI-API-compatible gateway; one key, every
# provider). If OPENROUTER_API_KEY is set, the server ignores
# OPENAI_API_KEY and routes all calls to openrouter.ai. Fall back to
# raw OpenAI by setting only OPENAI_API_KEY.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# Optional OpenRouter attribution (shown on their public leaderboard
# and used for rate-limit attribution on free models).
OPENROUTER_REFERER=https://cosmic-agents.com
OPENROUTER_TITLE=Cosmic Agents

# ---- Model routing (per role) ----
# Defaults below assume OpenRouter. If you switch to raw OpenAI,
# drop the "provider/" prefix (e.g. openai/gpt-4o-mini -> gpt-4o-mini).
# Specialist-agent default. Fast + cheap for per-turn work.
OPENAI_MODEL=openai/gpt-4o-mini
# Planner picks the crew once per run; a fast model handles the JSON schema.
PLANNER_MODEL=openai/gpt-4o-mini
# LEADER_MODEL is the "careful reasoning" brand — used only as the
# default fallback for HEARTBEAT_MODEL below. Conversational Leader
# turns, task briefs, and selector calls don't touch it.
LEADER_MODEL=openai/o1
# Conversational Leader replies (every Leader turn that ISN'T a
# heartbeat). Fast model. Coordination + nominations, not deep reasoning.
LEADER_CHAT_MODEL=openai/gpt-4o-mini
# Task Brief D at t=0: structured JSON decomposition. Fast model handles
# this in 1-2s; o1 used to take 8-12s for no quality gain.
TASK_BRIEF_MODEL=openai/gpt-4o-mini
# Heartbeat (every LEADER_CHECKIN_INTERVAL turns): coverage/consistency
# scoring + terminate decision. Reasoning pays off here — default to o1.
HEARTBEAT_MODEL=openai/o1
# Selector is the highest-frequency call (once per non-nomination turn).
# Gemini 2.0 Flash is the fastest sub-1s option on OpenRouter.
SELECTOR_MODEL=google/gemini-2.0-flash-exp
# Finalizer produces the single user-facing answer. Claude 3.5 Sonnet
# is the strongest model for structured long-form synthesis and doesn't
# burn budget on hidden reasoning tokens (which was the o1 failure mode
# that kept triggering the deterministic fallback).
FINALIZER_MODEL=anthropic/claude-3.5-sonnet

ENABLE_PROMPT_OPTIMIZER=true
OPTIMIZER_MODEL=openai/gpt-4o-mini
ENABLE_USER_CLARIFICATIONS=true
CLARIFIER_MODEL=openai/gpt-4o-mini
MAX_CLARIFICATION_QUESTIONS=5

# ---- Token budgets ----
MAX_INPUT_TOKENS=25000
MAX_OUTPUT_TOKENS=25000
PLANNER_MAX_OUTPUT_TOKENS=2000
# Leader can run on o1 for heartbeat; reasoning tokens count against this cap.
LEADER_MAX_OUTPUT_TOKENS=4500
AGENT_MAX_OUTPUT_TOKENS=3000
# Finalizer produces the user-facing answer and must synthesize ALL
# specialist research. 12000 gives room for rich multi-section output.
# If you override FINALIZER_MODEL back to o1, keep this >= 12k.
FINALIZER_MAX_OUTPUT_TOKENS=12000
TOOL_CALL_MAX_TOKENS=2500
SELECTOR_MAX_OUTPUT_TOKENS=200
SELECTOR_MAX_OUTPUT_TOKENS_O1=200

# ---- Streaming / memory ----
ENABLE_STREAMING=true
ENABLE_MEMORY_SUMMARY=true
SUMMARY_MODEL=openai/gpt-4o-mini
SUMMARY_TRIGGER_CHARS=60000
SUMMARY_MIN_TURNS_BETWEEN=8

# ---- COSMIC coordination ----
# Heartbeat cadence. 5 guarantees at least one check-in on typical
# 6-10 turn runs so the Heartbeat panel in the UI actually populates.
LEADER_CHECKIN_INTERVAL=5

# ---- Web search (optional) ----
SEARCH_CACHE_TTL_MS=600000
SEARCH_CACHE_MAX_ENTRIES=200
SEARCH_BATCH_MAX_QUERIES=3
SERPER_API_KEY=

PORT=3000
