OPENAI_API_KEY=
# Specialist-agent default. gpt-4o-mini is ~10x faster than gpt-5 family
# for the per-turn specialist calls; reasoning models only earn their
# latency on Leader heartbeats and the final answer.
OPENAI_MODEL=gpt-4o-mini
# Planner picks the crew once per run; mini is plenty for that JSON schema.
PLANNER_MODEL=gpt-4o-mini
# Leader keeps o1: heartbeat checks coverage/consistency and decides
# when to TERMINATE. Worth the reasoning cost.
LEADER_MODEL=o1
# SELECTOR_MODEL is called ~N times per run (once per non-nomination turn).
# Keep it cheap and fast; the selection space is small (pick from a list
# of agent names) so a mini model performs indistinguishably from o1 here.
SELECTOR_MODEL=gpt-4o-mini
# Finalizer stays on o1: this is the single user-facing answer.
FINALIZER_MODEL=o1
ENABLE_PROMPT_OPTIMIZER=true
OPTIMIZER_MODEL=gpt-4o-mini
ENABLE_USER_CLARIFICATIONS=true
CLARIFIER_MODEL=gpt-4o-mini
MAX_CLARIFICATION_QUESTIONS=5
MAX_INPUT_TOKENS=25000
MAX_OUTPUT_TOKENS=25000
PLANNER_MAX_OUTPUT_TOKENS=2000
LEADER_MAX_OUTPUT_TOKENS=2500
AGENT_MAX_OUTPUT_TOKENS=3000
FINALIZER_MAX_OUTPUT_TOKENS=5000
TOOL_CALL_MAX_TOKENS=2500
SELECTOR_MAX_OUTPUT_TOKENS=200
SELECTOR_MAX_OUTPUT_TOKENS_O1=200
ENABLE_STREAMING=true
ENABLE_MEMORY_SUMMARY=true
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_TRIGGER_CHARS=60000
SUMMARY_MIN_TURNS_BETWEEN=8
LEADER_CHECKIN_INTERVAL=10
SEARCH_CACHE_TTL_MS=600000
SEARCH_CACHE_MAX_ENTRIES=200
SEARCH_BATCH_MAX_QUERIES=3
SERPER_API_KEY=
PORT=3000
