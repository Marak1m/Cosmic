OPENAI_API_KEY=
# Specialist-agent default. gpt-5.4-mini is ~10x faster than gpt-5 family
# for the per-turn specialist calls; reasoning models only earn their
# latency on Leader heartbeats and the final answer.
OPENAI_MODEL=gpt-5.4-mini
# Planner picks the crew once per run; mini is plenty for that JSON schema.
PLANNER_MODEL=gpt-5.4-mini
# LEADER_MODEL is the "careful reasoning brand" — now used only as the
# default fallback for HEARTBEAT_MODEL below. Conversational Leader
# turns, task brief generation, and selector calls no longer touch it.
# This is what keeps total run time under control: per-turn Leader
# replies used to pay o1's 10-30s reasoning tax; now they don't.
LEADER_MODEL=o1
# Conversational Leader replies (every Leader turn that ISN'T a
# heartbeat). Fast model. The Leader's job on normal turns is
# coordination + nominations, not deep reasoning.
LEADER_CHAT_MODEL=gpt-5.4-mini
# Task Brief D at t=0: structured JSON decomposition. A fast model
# handles this in 1-2s; o1 used to take 8-12s for no quality gain.
TASK_BRIEF_MODEL=gpt-5.4-mini
# Heartbeat (every LEADER_CHECKIN_INTERVAL turns): coverage/consistency
# scoring + terminate decision. This IS where reasoning pays off, so
# default to LEADER_MODEL (o1). Override to gpt-5.4-mini if you want
# even faster runs at the cost of looser stop criteria.
HEARTBEAT_MODEL=o1
# SELECTOR_MODEL is called ~N times per run (once per non-nomination turn).
# Keep it cheap and fast; the selection space is small (pick from a list
# of agent names) so a mini model performs indistinguishably from o1 here.
SELECTOR_MODEL=gpt-5.4-mini
# Finalizer stays on o1: this is the single user-facing answer.
FINALIZER_MODEL=o1
ENABLE_PROMPT_OPTIMIZER=true
OPTIMIZER_MODEL=gpt-5.4-mini
ENABLE_USER_CLARIFICATIONS=true
CLARIFIER_MODEL=gpt-5.4-mini
MAX_CLARIFICATION_QUESTIONS=5
MAX_INPUT_TOKENS=25000
MAX_OUTPUT_TOKENS=25000
PLANNER_MAX_OUTPUT_TOKENS=2000
# Leader runs on o1 and reasoning tokens count against this cap; 2500
# was leaving essentially no headroom for visible heartbeat output.
LEADER_MAX_OUTPUT_TOKENS=4500
AGENT_MAX_OUTPUT_TOKENS=3000
# Finalizer produces the user-facing answer and must synthesize ALL
# specialist research. On o1 this cap includes hidden reasoning
# tokens, so 5000 was sometimes producing a bare "TERMINATE". 12000
# leaves room for a rich synthesis plus o1's reasoning overhead.
FINALIZER_MAX_OUTPUT_TOKENS=12000
TOOL_CALL_MAX_TOKENS=2500
SELECTOR_MAX_OUTPUT_TOKENS=200
SELECTOR_MAX_OUTPUT_TOKENS_O1=200
ENABLE_STREAMING=true
ENABLE_MEMORY_SUMMARY=true
SUMMARY_MODEL=gpt-5.4-mini
SUMMARY_TRIGGER_CHARS=60000
SUMMARY_MIN_TURNS_BETWEEN=8
LEADER_CHECKIN_INTERVAL=10
SEARCH_CACHE_TTL_MS=600000
SEARCH_CACHE_MAX_ENTRIES=200
SEARCH_BATCH_MAX_QUERIES=3
SERPER_API_KEY=
PORT=3000
